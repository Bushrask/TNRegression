{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": ".",
    "outDir": "./dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "noEmit":true
  },
  "include": [
    "tests/**/*.ts",
    "support/**/*.ts",
    "PageObjects/**/*.ts"
  ]
}